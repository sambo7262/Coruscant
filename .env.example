# =============================================================================
# Coruscant Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# This file controls infrastructure variables ONLY.
# Service URLs and API keys are configured in the Settings UI (Phase 3+).
# =============================================================================

# --- Docker Hub Image ---
# Your Docker Hub username/repo for pulling images
DOCKER_HUB_REPO=yourusername/coruscant
IMAGE_TAG=latest

# --- Network ---
# Port exposed on the host (NAS LAN IP:PORT)
PORT=3000

# --- Data Persistence ---
# Absolute path on the host where SQLite database is stored
# Synology NAS convention: /volume1/docker/<app-name>
DATA_PATH=/volume1/docker/coruscant

# --- NAS User/Group IDs ---
# Find your values: SSH into NAS and run `id <your-user>`
# These ensure the container can read/write the bind-mounted data directory
PUID=1026
PGID=100

# --- Security ---
# Seed for encrypting service credentials stored in SQLite (Phase 3+)
# Generate a random value: openssl rand -hex 32
# NEVER commit the actual value — this file is in .gitignore
ENCRYPTION_KEY_SEED=changeme-replace-with-random-hex
