{
  "name": "coruscant",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "build:backend": "tsc --build packages/backend/tsconfig.json",
    "build:frontend": "npm run build --workspace=packages/frontend",
    "dev:backend": "npm run dev --workspace=packages/backend",
    "dev:frontend": "npm run dev --workspace=packages/frontend",
    "test": "vitest run",
    "prepare": "husky || true",
    "lint": "node scripts/verify-viewport-isolation.mjs"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "tsx": "^4.21.0",
    "vitest": "^4.1.2",
    "@types/node": "^22.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}
